{
  "printWidth": 120,
  "singleQuote": true,
  "trailingComma": "es5",
  "semi": false,
  "tabWidth": 2,
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "plugins": [
    "@trivago/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss"
  ],
  "importOrder": [
    "^path$",
    "^vite$",
    "^react",
    "<THIRD_PARTY_MODULES>",
    "^@/",
    "^[./]"
  ]
}
