{
  "name": "@living-craft/root",
  "private": true,
  "workspaces": {
    "packages": [
      "living-craft-front",
      "living-craft-backend",
      "living-craft-backoffice",
      "packages/*"
    ],
    "nohoist": [
      "**/react-native",
      "**/react-native/**",
      "**/@apps-in-toss/**",
      "**/@granite-js/**",
      "**/metro",
      "**/metro/**",
      "**/babel-preset-granite",
      "**/jest",
      "**/jest/**"
    ]
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:front": "yarn workspace @living-craft/front run dev",
    "dev:backend": "yarn workspace @living-craft/backend run dev",
    "dev:backoffice": "yarn workspace @living-craft/backoffice run dev",
    "dev:ad": "yarn --cwd asset-diary-front dev",
    "dev:ad:back": "yarn workspace @living-craft/backend run dev",
    "build:ad": "yarn --cwd asset-diary-front build",
    "typecheck:ad": "yarn --cwd asset-diary-front typecheck",
    "build": "turbo run build",
    "build:front": "turbo run build --filter=@living-craft/front",
    "build:backend": "turbo run build --filter=@living-craft/backend",
    "build:backoffice": "turbo run build --filter=@living-craft/backoffice",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore",
    "clean": "rm -rf node_modules **/node_modules",
    "reset": "yarn clean && yarn install"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "eslint": "^9.39.1",
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint-plugin-prettier": "^5.5.4",
    "typescript-eslint": "^8.49.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "prettier-plugin-tailwindcss": "^0.7.1"
  },
  "packageManager": "yarn@1.22.22"
}
