{
  "name": "@living-craft/root",
  "private": true,
  "workspaces": {
    "packages": [
      "living-craft-backend",
      "packages/*"
    ],
    "nohoist": [
      "**/react-native",
      "**/react-native/**",
      "**/@apps-in-toss/**",
      "**/@granite-js/**",
      "**/metro",
      "**/metro/**",
      "**/babel-preset-granite",
      "**/jest",
      "**/jest/**"
    ]
  },
  "scripts": {
    "dev:back": "yarn workspace @living-craft/backend run start:dev",
    "dev:ad": "yarn --cwd asset-diary-front dev",
    "dev:pc": "npm --prefix pc-front run dev",
    "dev:ib": "npm --prefix ib-front run dev",
    "dev:jip": "npm --prefix jip-front run dev",
    "build:ad": "yarn --cwd asset-diary-front build",
    "build:pc": "npm --prefix pc-front run build",
    "typecheck:ad": "yarn --cwd asset-diary-front typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore",
    "clean": "rm -rf node_modules **/node_modules",
    "reset": "yarn clean && yarn install"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "eslint": "^9.39.1",
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint-plugin-prettier": "^5.5.4",
    "typescript-eslint": "^8.49.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "prettier-plugin-tailwindcss": "^0.7.1"
  },
  "packageManager": "yarn@1.22.22"
}
